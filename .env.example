APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

# Ruta al binario de mysqldump (ejemplo para XAMPP en Windows)
# DB_DUMP_BINARY_PATH=C:\\xampp\\mysql\\bin

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=180
JWT_TTL=180

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ========================================
# Configuración de Descargas de Datos Externos
# ========================================

# PROXY CORPORATIVO (si aplica)
# Descomentar y configurar si la aplicación está detrás de un proxy corporativo
# HTTP_PROXY=http://proxy.empresa.com:8080
# HTTPS_PROXY=https://proxy.empresa.com:8080
# NO_PROXY=localhost,127.0.0.1,.local

# Control de descargas externas
EXTERNAL_DOWNLOADS_ENABLED=true
EXTERNAL_DOWNLOADS_DEBUG=false
EXTERNAL_DOWNLOADS_VERIFY_SSL=false
EXTERNAL_DOWNLOADS_CACHE_DRIVER=file
EXTERNAL_DOWNLOADS_CACHE_DISABLED=false
EXTERNAL_DOWNLOADS_LOG_ENABLED=true

# Timeouts (segundos)
EXTERNAL_DOWNLOADS_TIMEOUT=15
EXTERNAL_DOWNLOADS_CONNECT_TIMEOUT=10

# Servicios individuales
VALOR_UR_ENABLED=true
VALOR_UR_URL=https://www.bps.gub.uy/bps/valores.jsp?contentid=5478

SINCRONIZACION_HORA_ENABLED=true

VALORES_SOA_ENABLED=true
VALORES_SOA_URL_SOURCE=https://www.bcu.gub.uy/Servicios-Financieros-SSF/Paginas/ImpPromCostoDelSOA.aspx
